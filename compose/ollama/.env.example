# Copy to .env and adjust. Every value has a working default.

# Ollama image tag — pinned for reproducibility, bump deliberately
OLLAMA_IMAGE_TAG=0.31.1

# Host port the Ollama API is published on
OLLAMA_HOST_PORT=11434

# How long a model stays loaded in VRAM after the last request
OLLAMA_KEEP_ALIVE=5m

# Model pulled and exercised by scripts/smoke-test.sh
OLLAMA_MODEL=qwen3.5:9b
