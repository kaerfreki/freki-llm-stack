# Copy to .env and adjust. Every value has a working default.

# vLLM image tag — pinned for reproducibility, bump deliberately
VLLM_IMAGE_TAG=v0.25.0

# Host port the OpenAI-compatible API is published on
VLLM_HOST_PORT=8000

# Hugging Face model id (one model per process).
# Default is the ~4-bit counterpart of Ollama's qwen3.5:9b — see
# ../../benchmarks/MODEL-MAP-vllm.md for the full apples-to-apples matrix.
VLLM_MODEL=cyankiwi/Qwen3.5-4B-AWQ-INT8-INT4

# Context window reserved at startup (lower = less VRAM for the KV cache).
# 4096 is enough for the long-prompt bench (~1.2k tokens in + 128 out).
VLLM_MAX_MODEL_LEN=4096

# Fraction of free GPU memory vLLM may claim for weights + KV
# 0.80 leaves headroom for the desktop on a single consumer GPU (~2 GiB)
VLLM_GPU_MEMORY_UTILIZATION=0.80

# Weight dtype: auto | half | bfloat16 | float16 | float32
VLLM_DTYPE=auto

# Hugging Face token — only needed for gated models (not required by the default map)
# HF_TOKEN=
